{
  "name": "dexvault-backend",
  "version": "0.0.1",
  "description": "DexVault Backend - Express.js backend for DexVault media collection manager",
  "dependencies": {
    "@jest/globals": "^29.7.0",
    "adm-zip": "^0.5.16",
    "archiver": "^7.0.1",
    "axios": "^1.12.0",
    "cors": "^2.8.5",
    "csv-parser": "^3.2.0",
    "dotenv": "^17.2.2",
    "express": "^5.1.0",
    "multer": "^2.0.2",
    "sharp": "^0.33.0",
    "sqlite3": "^5.1.7",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/archiver": "^7.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.0.0",
    "@types/node": "^25.3.0",
    "@types/supertest": "^6.0.3",
    "@types/uuid": "^10.0.0",
    "jest": "^29.7.0",
    "js-yaml": "^4.1.1",
    "nodemon": "^3.0.1",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.6",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "start": "node index.js",
    "start:ts": "tsx index.ts",
    "dev": "tsx watch index.ts -- --deployment=../deployment.dev.json",
    "build": "tsc",
    "prod": "tsx index.ts --deployment=../deployment.prod.json",
    "test": "jest --setupFilesAfterEnv=./tests/setup.js"
  },
  "jest": {
    "testEnvironment": "node",
    "setupFilesAfterEnv": [
      "./tests/setup.js"
    ],
    "transform": {
      "^.+\\.tsx?$": "ts-jest"
    },
    "moduleFileExtensions": ["ts", "tsx", "js", "jsx", "json"]
  }
}
